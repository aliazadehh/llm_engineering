# Telegram Bot API
# Create a bot via @BotFather on Telegram, then /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your Telegram chat ID — send /start to @userinfobot to find it
# Positive integer for personal chat; negative integer for group chat
TELEGRAM_CHAT_ID=987654321

# OpenAI API key for condition classification (GPT OSS 120B)
OPENAI_API_KEY=sk-...

# Optional overrides
# DB_PATH=seen_listings.db
# LOG_DIR=logs
